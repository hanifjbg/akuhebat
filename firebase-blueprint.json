{
  "entities": {
    "WordBankEntry": {
      "title": "WordBankEntry",
      "description": "Represents a single word entry in the word bank",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The actual word, e.g., 'pesawat'" },
        "syllables": { "type": "array", "items": { "type": "string" }, "description": "['pe', 'sa', 'wat']" },
        "letters": { "type": "array", "items": { "type": "string" }, "description": "['p','e','s','a','w','a','t']" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "level": { "type": "number", "description": "Base difficulty level" },
        "lessonId": { "type": "string", "description": "Optional link to a specific lesson" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["text", "syllables", "letters", "level", "createdAt"]
    },
    "LearningModule": {
      "title": "LearningModule",
      "description": "A top-level category of learning (e.g., Module 1: Vowels)",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "order": { "type": "number" },
        "description": { "type": "string" },
        "requiredLevel": { "type": "number" },
        "icon": { "type": "string" }
      },
      "required": ["title", "order", "requiredLevel"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "A specific lesson within a module",
      "type": "object",
      "properties": {
        "moduleId": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "number" },
        "content": { "type": "string" },
        "isFree": { "type": "boolean" }
      },
      "required": ["moduleId", "title", "order"]
    },
    "ChildProfile": {
      "title": "ChildProfile",
      "description": "Child's gamification progress",
      "type": "object",
      "properties": {
        "parentId": { "type": "string" },
        "name": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "level": { "type": "number" },
        "exp": { "type": "number" },
        "stars": { "type": "number" },
        "unlockedModuleIds": { "type": "array", "items": { "type": "string" } },
        "completedLessonIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["parentId", "name", "level", "exp", "stars"]
    }
  },
  "firestore": {
    "/word-bank/{wordId}": {
      "schema": { "$ref": "#/entities/WordBankEntry" },
      "description": "Global word bank for quizzes."
    },
    "/learning-modules/{moduleId}": {
      "schema": { "$ref": "#/entities/LearningModule" },
      "description": "Standardized learning modules."
    },
    "/learning-modules/{moduleId}/lessons/{lessonId}": {
      "schema": { "$ref": "#/entities/Lesson" },
      "description": "Lessons within modules."
    },
    "/parents/{parentId}/children/{childId}": {
      "schema": { "$ref": "#/entities/ChildProfile" },
      "description": "Child profiles and their learning progress."
    }
  }
}
